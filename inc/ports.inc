;=========================================================
;
; Pentagon 1024 / SBIOS
; Hardware Ports
;
;=========================================================

;---------------------------------------------------------
; ULA
;---------------------------------------------------------

PORT_FE             EQU #FE

;---------------------------------------------------------
; Memory paging
;---------------------------------------------------------

PORT_7FFD           EQU #7FFD
PORT_1FFD           EQU #1FFD

;---------------------------------------------------------
; Kempston
;---------------------------------------------------------

PORT_KEMPSTON       EQU #1F

;---------------------------------------------------------
; AY-3-8912
;---------------------------------------------------------

PORT_AY_INDEX       EQU #FFFD
PORT_AY_DATA        EQU #BFFD

;---------------------------------------------------------
; Nemo IDE
;---------------------------------------------------------

IDE_DATA            EQU #0010
IDE_ERROR           EQU #0011
IDE_FEATURES        EQU #0011

IDE_SECCNT          EQU #0012
IDE_SECTOR          EQU #0013
IDE_CYL_LOW         EQU #0014
IDE_CYL_HIGH        EQU #0015
IDE_HEAD            EQU #0016
IDE_STATUS          EQU #0017
IDE_COMMAND         EQU #0017

;---------------------------------------------------------
; IDE Status
;---------------------------------------------------------

IDE_BSY             EQU %10000000
IDE_DRDY            EQU %01000000
IDE_DF              EQU %00100000
IDE_DRQ             EQU %00001000
IDE_ERR             EQU %00000001

;---------------------------------------------------------
; IDE Commands
;---------------------------------------------------------

IDE_CMD_RESET       EQU #08

IDE_CMD_IDENTIFY    EQU #EC

IDE_CMD_READ        EQU #20

IDE_CMD_WRITE       EQU #30

;---------------------------------------------------------
; Border colors
;---------------------------------------------------------

BORDER_BLACK        EQU 0
BORDER_BLUE         EQU 1
BORDER_RED          EQU 2
BORDER_MAGENTA      EQU 3
BORDER_GREEN        EQU 4
BORDER_CYAN         EQU 5
BORDER_YELLOW       EQU 6
BORDER_WHITE        EQU 7